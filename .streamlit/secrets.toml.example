# Streamlit Community Cloud secrets template.
# Copy the values from your local .env into Streamlit's Secrets UI.

LLM_PROVIDER = "gemini"
GEMINI_API_KEY = "your_gemini_api_key"
GEMINI_MODEL = "gemini-2.0-flash"
GEMINI_EMBEDDING_MODEL = "models/text-embedding-004"

OPENAI_API_KEY = "your_openai_api_key"
OPENAI_MODEL = "gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL = "text-embedding-3-small"
OPENAI_TEMPERATURE = "0"

OLLAMA_BASE_URL = "http://localhost:11434"
OLLAMA_MODEL = "llama3.1:8b"
OLLAMA_EMBEDDING_MODEL = "nomic-embed-text"

GITHUB_TOKEN = "your_github_token"
GITHUB_WEBHOOK_SECRET = "your_webhook_secret"
GITHUB_API_URL = "https://api.github.com"
GITHUB_STATUS_CONTEXT = "ai-code-review"
GITHUB_STATUS_FAIL_SEVERITY = "high"

GITHUB_APP_ID = ""
GITHUB_INSTALLATION_ID = ""
GITHUB_PRIVATE_KEY_PATH = ""

REVIEW_HISTORY_DB_PATH = "/tmp/review_history.db"
REPOSITORY_INDEX_PATH = "/tmp/repository_index.json"
